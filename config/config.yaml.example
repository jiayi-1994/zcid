server:
  port: "8080"
  log_level: "info"

database:
  host: "localhost"
  port: 5432
  name: "zcid"
  user: "zcid"
  password: ""  # Use DB_PASSWORD env var instead
  ssl_mode: "disable"

redis:
  host: "localhost"
  port: 6379
  password: ""  # Use REDIS_PASSWORD env var instead
  db: 0

minio:
  endpoint: "localhost:9000"
  access_key: "minioadmin"
  secret_key: ""  # Use MINIO_SECRET_KEY env var instead
  use_ssl: false

auth:
  jwt_secret: ""  # Use JWT_SECRET env var instead

step_executions:
  retention_days: 90
